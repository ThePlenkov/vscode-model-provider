{
  "name": "@theplenkov/adapter-claude",
  "version": "0.1.0",
  "description": "Claude Code ACP adapter: exports a BuiltinAdapter entry (cliCommand='claude', cliArgs=['--acp']) plus the model-mapping table. Consumed by @theplenkov/acp-core's discovery layer. Agent-specific — Claude Code only.",
  "type": "module",
  "private": true,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prepare": "npm run build",
    "build": "tsdown",
    "watch": "tsdown --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --max-warnings 0"
  },
  "dependencies": {
    "@theplenkov/claude-config": "*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}