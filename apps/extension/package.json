{
  "name": "vscode-model-provider",
  "displayName": "ACP Model Provider",
  "description": "Expose ACP-compatible agent models (Claude Code, Gemini CLI, Codex, OpenCode, and more) to VS Code Copilot Chat via the LanguageModelChatProvider API",
  "version": "0.2.0",
  "type": "module",
  "publisher": "theplenkov",
  "repository": {
    "type": "git",
    "url": "https://github.com/ThePlenkov/vscode-model-provider"
  },
  "keywords": [
    "vscode",
    "copilot",
    "acp",
    "agent",
    "claude-code",
    "gemini-cli",
    "language-model"
  ],
  "engines": {
    "vscode": "^1.104.0",
    "node": ">=18"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [
    "onLanguageModelChatProvider:acp"
  ],
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "acp",
        "displayName": "ACP Agents"
      }
    ]
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "tsdown",
    "watch": "tsdown --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "package": "npx @vscode/vsce package --no-dependencies",
    "test": "npm run typecheck && npm run test:unit",
    "test:unit": "npx vitest run --config vitest.config.ts",
    "test:unit:watch": "npx vitest --config vitest.config.ts",
    "test:host": "node test/runTest.ts"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.104.0",
    "@vscode/test-electron": "^3.0.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "main": "./dist/extension.mjs",
  "module": "./dist/extension.mjs",
  "types": "./dist/extension.d.mts",
  "exports": {
    ".": "./dist/extension.mjs",
    "./package.json": "./package.json"
  }
}
