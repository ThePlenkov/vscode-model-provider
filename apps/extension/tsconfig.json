{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "strict": false,
    "outDir": "./out",
    "rootDir": "./src",
    "declaration": true,
    "sourceMap": true,
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": false,
    "types": ["node"]
  },
  "include": ["src", "vscode.d.ts"],
  "exclude": ["node_modules", "out", "src/test"]
}
